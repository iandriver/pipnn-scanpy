+class BuildExt(build_ext):
+    """Portable build: per-arch SIMD baseline + OpenMP/rt handled per platform.
+
+    The upstream build hardcoded ``-march=native -lrt -fopenmp`` (x86/Linux only),
+    which bakes in the *builder's* ISA (e.g. AVX-512 → SIGILL elsewhere) and won't
+    link on macOS. Here we pick a portable baseline so one wheel per arch runs
+    across that whole arch:
+
+    * x86_64 → ``-mavx2 -mfma -mf16c`` (AVX2/Haswell 2013+; defines ``__AVX2__``,
+      not ``__AVX512F__`` → the AVX2 distance kernels). Override with
+      ``GLASS_MARCH`` (e.g. ``-march=native`` or AVX-512 for a tuned local build).
+    * aarch64/arm64 → no flag needed; NEON is implicit (``__aarch64__`` → the NEON
+      kernels). Apple Silicon and Graviton both covered.
+    """
 
     def build_extensions(self):
-        opts = self.c_opts.get("unix", [])
+        import platform
+
+        system = platform.system()
+        mach = platform.machine().lower()
+
+        opts = ["-Ofast", "-fPIC", "-ftree-vectorize"]
         opts.append(f'-DVERSION_INFO="{self.distribution.get_version()}"')
         opts.append(cpp_flag(self.compiler))
         if has_flag(self.compiler, "-fvisibility=hidden"):
             opts.append("-fvisibility=hidden")
 
+        march = os.environ.get("GLASS_MARCH")
+        if march:
+            opts.append(march)
+        elif mach in ("x86_64", "amd64"):
+            opts += ["-mavx2", "-mfma", "-mf16c"]
+        # arm64/aarch64: NEON is implicit (no -march needed).
+
+        link = ["-pthread"]
+        if system == "Linux":
+            link.append("-lrt")
+        omp_c, omp_l = _omp_flags(self.compiler, system)
+        opts += omp_c
+        link += omp_l
+
         for ext in self.extensions:
             ext.extra_compile_args.extend(opts)
-            ext.extra_link_args.extend(self.link_opts.get("unix", []))
+            ext.extra_link_args.extend(link)
 
         build_ext.build_extensions(self)
 
